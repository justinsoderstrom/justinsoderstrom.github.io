<section class="comments" aria-label="Comments">
  <div class="giscus-container"></div>
</section>

{/* The giscus script is built dynamically so its initial data-theme can match
    the visitor's current theme, which is only known at runtime. */}
<script is:inline>
  (() => {
    const giscusTheme = () =>
      document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';

    const script = document.createElement('script');
    script.src = 'https://giscus.app/client.js';
    script.async = true;
    script.crossOrigin = 'anonymous';
    for (const [name, value] of Object.entries({
      'data-repo': 'justinsoderstrom/justinsoderstrom.github.io',
      'data-repo-id': 'R_kgDOTbEH9w',
      'data-category': 'Announcements',
      'data-category-id': 'DIC_kwDOTbEH984DBjAI',
      'data-mapping': 'pathname',
      'data-strict': '1',
      'data-reactions-enabled': '1',
      'data-emit-metadata': '0',
      'data-input-position': 'bottom',
      'data-theme': giscusTheme(),
      'data-lang': 'en',
      'data-loading': 'lazy',
    })) {
      script.setAttribute(name, value);
    }
    document.querySelector('.giscus-container').appendChild(script);

    // The theme toggle only mutates data-theme on <html>, so observe it and
    // forward changes to the giscus iframe.
    new MutationObserver(() => {
      const frame = document.querySelector('iframe.giscus-frame');
      if (!frame) return;
      const sendTheme = () =>
        frame.contentWindow?.postMessage(
          { giscus: { setConfig: { theme: giscusTheme() } } },
          'https://giscus.app',
        );
      sendTheme();
      // The iframe is lazy-loaded; a message sent before it loads is dropped
      // (its document is still about:blank), so re-send once it does load.
      frame.addEventListener('load', sendTheme, { once: true });
    }).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });
  })();
</script>

<style>
  .comments {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }
</style>
