---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    name: 'Runnel.AzureMonitor.RequestLogging',
    description:
      'Extended ASP.NET Core HTTP request & response body logging with Azure Monitor OpenTelemetry.',
    url: 'https://github.com/justinsoderstrom/runnel-azuremonitor-requestlogging',
    tech: 'C# · ASP.NET Core · OpenTelemetry',
  },
  {
    name: 'justinsoderstrom.com',
    description:
      'This website — a personal site built with Astro and deployed to GitHub Pages. Open source, so feel free to poke around.',
    url: 'https://github.com/justinsoderstrom/justinsoderstrom.github.io',
    tech: 'Astro · GitHub Pages',
  },
];
---

<BaseLayout
  title="Projects — Justin Soderstrom"
  description="Open-source projects and other software by Justin Soderstrom."
>
  <h1>Projects</h1>
  <p class="muted">
    A selection of things I've built. More
    on <a href="https://github.com/justinsoderstrom">GitHub</a>!
  </p>

  <ul class="card-list">
    {
      projects.map((project) => (
        <li class="card">
          <h2>
            <a href={project.url}>{project.name}</a>
          </h2>
          <p>{project.description}</p>
          <span class="meta">{project.tech}</span>
        </li>
      ))
    }
  </ul>
</BaseLayout>
