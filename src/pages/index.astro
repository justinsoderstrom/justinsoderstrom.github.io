---
import type { ImageMetadata } from 'astro';
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

// Drop a square photo at src/assets/portrait.jpg (or .png/.webp) and it
// shows up here automatically; delete the file to go back to text-only.
const portraitFiles = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/portrait.{jpg,jpeg,png,webp}',
  { eager: true },
);
const portrait = Object.values(portraitFiles)[0]?.default;

// Point JSON-LD at an optimized rendition rather than portrait.src, so the
// full-size original never ships in the build.
const portraitJsonLdImage = portrait
  ? await getImage({ src: portrait, width: 800, format: 'webp' })
  : undefined;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Justin Soderstrom',
  url: 'https://justinsoderstrom.com',
  jobTitle: 'Lead API Engineer',
  ...(portraitJsonLdImage && {
    image: new URL(portraitJsonLdImage.src, Astro.site).href,
  }),
  sameAs: [
    'https://github.com/justinsoderstrom',
    'https://www.linkedin.com/in/justinsoderstrom/',
  ],
};
---

<BaseLayout
  title="Justin Soderstrom — Lead API Engineer"
  description="Justin Soderstrom is a Lead API Engineer designing and delivering cloud-native .NET systems on Azure. Projects, resume, and writing on software development."
  jsonLd={jsonLd}
>
  <section class="hero">
    {
      portrait && (
        <Image
          src={portrait}
          alt="Portrait of Justin Soderstrom"
          width={112}
          densities={[1, 2]}
          class="hero-portrait"
          loading="eager"
          fetchpriority="high"
        />
      )
    }
    <div>
      <h1>Hi, I'm Justin.</h1>
      <p class="tagline">Lead API Engineer — building .NET applications on Azure</p>
    </div>
  </section>

  <p>
    I'm a Lead API Engineer at CCC Intelligent Solutions with nearly a decade
    of experience designing and delivering cloud-native .NET systems on Azure. 
    I build scalable ASP.NET Core APIs behind business-critical SaaS
    products, plus the occasional web or desktop application when the job
    calls for it.
  </p>

  <p>
    Beyond the code, I bridge product, architecture, and delivery: partnering
    with leadership on architecture decisions, modernizing legacy systems, and
    mentoring engineering teams.
  </p>

  <!--
    Note: Astro trims newline-only whitespace between text and tags, so the
    space separating a link from surrounding words must stay on the same line.
  -->
  <p>
    Lately I've been working with Azure Monitor and OpenTelemetry,
    including <a href="https://github.com/justinsoderstrom/runnel-azuremonitor-requestlogging">an open-source library</a> for
    richer HTTP request and response logging in ASP.NET Core.
  </p>

  <p>
    Have a look at my <a href="/projects/">projects</a>, skim
    my <a href="/resume/">resume</a>, or read the <a href="/blog/">blog</a> —
    and if you'd like to talk, <a href="/contact/">get in touch</a>.
  </p>
</BaseLayout>
